# Copy this file to `.env` (already in .gitignore) and fill in the value.
# `app/__init__.py` loads .env at import time, so any process that
# imports something from `app` will pick up these values automatically.
#
# Get an Anthropic API key at https://console.anthropic.com.

ANTHROPIC_API_KEY=sk-...

# Optional: set to 1 to bypass the Anthropic API and use canned, schema-valid
# responses instead. Useful for UI / design-system work when you don't want
# to spend API credits. The graph still runs end-to-end (including the
# teacher-review interrupt and the SSE progress stream) — just with mock
# content per subject.
LESSONFORGE_MOCK=0
